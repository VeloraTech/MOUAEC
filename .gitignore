# Specific files to ignore
password.txt
mouau-hero.html
desktop.ini
admin-rewrite.html

# OS Files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
backup/
snapshot/*
# IDE and Editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.code-workspace

# Node modules (if using npm)
node_modules/
npm-debug.log
yarn-error.log

# Build and dist directories
dist/
build/

# Environment files
.env
.env.local
.env.*.local
.env.*
!.env.example
!**/.env.example

# Temporary files
*.tmp
*.temp
*.log

# Backend runtime artifacts
backend/node_modules/
backend/logs/
backend/pids/
backend/coverage/
backend/.nyc_output/
backend/*.pid
backend/*.pid.lock
