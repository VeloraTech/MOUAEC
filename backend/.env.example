NODE_ENV=development
PORT=3000

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# IMPORTANT: use service role key (not anon key)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# Direct Postgres connection string from Supabase (Session pooler or direct)
SUPABASE_DB_URL=postgresql://postgres.your-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# Vote conversion
VOTE_PRICE=100

# Frontend domain for CORS (comma separated for multiple)
ALLOWED_ORIGINS=https://your-frontend-domain.com
